# =====================================================
# MIZIZZI E-COMMERCE PLATFORM - ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env and fill in your values
# For local development: leave Redis/Upstash empty (will use in-memory cache)
# For Render production: add Upstash credentials for distributed caching

# Flask Configuration
FLASK_CONFIG=development
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production-12345

# Database Configuration - Neon PostgreSQL (shared across local and Render)
DATABASE_URL=postgresql://neondb_owner:npg_0gMwASZYo9pJ@ep-shiny-term-adlossxs-pooler.c-2.us-east-1.aws.neon.tech/mizizzi_project?sslmode=require&channel_binding=require

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production-abcdef123
JWT_COOKIE_SECURE=false

# =====================================================
# Redis / Upstash Configuration (OPTIONAL)
# =====================================================
# For LOCAL DEVELOPMENT: Leave these EMPTY
# The app will use in-memory caching automatically
#
# For RENDER PRODUCTION: Add your Upstash REST API credentials
# Get these from https://console.upstash.com/
# DO NOT use REDIS_URL (that's traditional Redis, not REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# File Upload Configuration
UPLOAD_FOLDER=./uploads
UPLOAD_URL_PREFIX=/api/uploads
MAX_CONTENT_LENGTH=16777216

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# =====================================================
# Email Configuration (Brevo SMTP)
# =====================================================
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-brevo-smtp-user
MAIL_PASSWORD=your-brevo-smtp-password
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@mizizzi.shop
BREVO_SENDER_NAME=MIZIZZI
MAIL_DEFAULT_SENDER=noreply@mizizzi.shop

# =====================================================
# Google OAuth Configuration
# =====================================================
GOOGLE_CLIENT_ID=114775886111-eeboja3q4dff66t6dfro4v15diduodm8.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# =====================================================
# Payment Gateway - Pesapal
# =====================================================
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_MERCHANT_REFERENCE=your-pesapal-merchant-ref

# =====================================================
# Real-time Communication
# =====================================================
ENABLE_SOCKETIO=true

# =====================================================
# Image Upload - Cloudinary
# =====================================================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# =====================================================
# Search Engine - Meilisearch
# =====================================================
# For LOCAL: Meilisearch should run on localhost:7700
# For RENDER: Add your Render Meilisearch instance URL
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=test-api-key-change-in-production

# =====================================================
# Logging
# =====================================================
LOG_TO_STDOUT=false

# =====================================================
# Rate Limiting (Optional - uses memory by default)
# =====================================================
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=1000 per hour

# =====================================================
# Cache Configuration (Optional - uses in-memory by default)
# =====================================================
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300

